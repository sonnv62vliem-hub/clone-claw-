---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/posts';

export async function getStaticPaths() {
  return posts.map(post => ({
    params: { category: post.categorySlug, slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

function formatDate(date: Date) {
  return date.toLocaleDateString('vi-VN', { 
    day: '2-digit', 
    month: '2-digit', 
    year: 'numeric' 
  });
}

const categoryLabels: Record<string, string> = {
  'docs': 'Docs',
  'tin-tuc-ai': 'Tin tức AI',
  'design-system': 'Design System',
};

const categoryLabel = categoryLabels[post.categorySlug] || post.categorySlug;
const ogImage = post.seoOgImageUrl 
  ? `https://claw.ai.vn${post.seoOgImageUrl}` 
  : 'https://claw.ai.vn/og-image.jpg';
const canonical = `https://claw.ai.vn/${post.categorySlug}/${post.slug}`;
---

<Layout 
  title={post.seoTitle || post.title}
  description={post.seoDescription || post.shortDescription}
  ogImage={ogImage}
  canonical={canonical}
  currentPath={`/${post.categorySlug}/${post.slug}`}
>
  <article class="post-detail">
    <!-- Breadcrumb -->
    <nav class="post-breadcrumb">
      <a href="/">Trang chủ</a>
      <span>/</span>
      <a href="/posts">Bài viết</a>
      <span>/</span>
      <a href={`/posts?category=${post.categorySlug}`}>{categoryLabel}</a>
      <span>/</span>
      <span>{post.title}</span>
    </nav>
    
    <div class="post-detail-header">
      <!-- Category Badge -->
      <div class="post-category-badge">{categoryLabel}</div>
      
      <!-- Title -->
      <h1 class="post-detail-title">{post.title}</h1>
      
      <!-- Meta -->
      <div class="post-meta">
        <span>{formatDate(post.publishedAt)}</span>
        {post.seoKeywords && (
          <span>·</span>
          <span>{post.seoKeywords.split(',').slice(0, 3).join(', ')}</span>
        )}
      </div>
      
      <!-- Short Description -->
      {post.shortDescription && (
        <p class="post-short-desc">{post.shortDescription}</p>
      )}
    </div>
    
    <!-- Featured Image -->
    {post.featuredImageUrl && (
      <div class="post-featured-image">
        <img 
          src={post.featuredImageUrl.startsWith('/') ? `https://claw.ai.vn${post.featuredImageUrl}` : post.featuredImageUrl}
          alt={post.featuredImageAlt || post.title}
          loading="eager"
        />
      </div>
    )}
    
    <!-- Content -->
    <div class="prose-content" set:html={post.content}></div>
    
    <!-- Back to posts -->
    <div class="post-back" style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--glass-border);">
      <a href="/posts" class="glass-btn ghost">
        ← Xem tất cả bài viết
      </a>
    </div>
  </article>
</Layout>

<script>
  // Initialize tabs functionality
  document.addEventListener('DOMContentLoaded', () => {
    // Find all tabs-block elements
    const tabsBlocks = document.querySelectorAll('.tabs-block');
    
    tabsBlocks.forEach((tabsBlock) => {
      const tabButtons = tabsBlock.querySelectorAll('.tab-item');
      const tabContents = tabsBlock.querySelectorAll('.tab-content');
      
      tabButtons.forEach((button, index) => {
        button.addEventListener('click', () => {
          // Remove active class from all buttons
          tabButtons.forEach(btn => btn.classList.remove('active'));
          // Add active class to clicked button
          button.classList.add('active');
          
          // Hide all contents
          tabContents.forEach(content => content.classList.remove('active'));
          // Show selected content
          if (tabContents[index]) {
            tabContents[index].classList.add('active');
          }
        });
      });
    });
  });
</script>

<style>
  .post-short-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.7;
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 4px solid var(--color-primary, #e63946);
    border-radius: 0 0.5rem 0.5rem 0;
  }
</style>
