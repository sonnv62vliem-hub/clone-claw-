---
import '../styles/global.css';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.svelte';
import MobileFAB from '../components/MobileFAB.svelte';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  currentPath?: string;
}

const {
  title = 'claw.ai.vn — OpenClaw AI Cho Người Mới và Ứng Dụng AI Thực Tế',
  description = 'OpenClaw AI cho người mới và mở rộng sang AI ứng dụng thực tế: tạo trợ lý cá nhân, tùy chỉnh agent, xây automation theo lộ trình rõ ràng.',
  ogImage = 'https://claw.ai.vn/og-image.jpg',
  canonical = 'https://claw.ai.vn/',
  currentPath = '/',
} = Astro.props;
---

<!doctype html>
<html lang="vi" data-theme="lobsterglass-light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="https://claw.ai.vn/_app/immutable/assets/claw-logo-red.DgE5HcFa.png" />
    
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <script>
      (function () {
        var saved = localStorage.getItem('theme');
        if (saved) document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
    
    <div class="foam-layer"></div>
    
    <script>
      // Mobile theme toggle functionality
      document.addEventListener('DOMContentLoaded', function() {
        const mobileThemeToggle = document.querySelector('.mobile-theme-toggle');
        if (mobileThemeToggle) {
          mobileThemeToggle.addEventListener('click', function() {
            const currentTheme = document.documentElement.getAttribute('data-theme');
            const newTheme = currentTheme === 'lobsterglass-dark' ? 'lobsterglass-light' : 'lobsterglass-dark';
            document.documentElement.setAttribute('data-theme', newTheme);
            localStorage.setItem('theme', newTheme);
          });
        }
      });
    </script>
    
    <div class="drawer drawer-end">
      <input id="app-drawer" type="checkbox" class="drawer-toggle" />
      
      <div class="app-shell drawer-content flex flex-col">
        <Navbar client:load currentPath={currentPath} />
        
        <main class="main-content">
          <div class="content-container">
            <slot />
          </div>
        </main>
        
        <Footer client:load />
        
        <MobileFAB client:load currentPath={currentPath} />
      </div>
      
      <!-- Mobile Drawer Side -->
      <div class="drawer-side z-[60]">
        <label for="app-drawer" aria-label="close sidebar" class="drawer-overlay"></label>
        <div class="mobile-menu-glass menu flex min-h-full w-80 flex-col items-end gap-2 p-6 pt-14">
          <label for="app-drawer" class="drawer-close-btn" aria-label="Đóng menu">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18"/>
              <path d="m6 6 12 12"/>
            </svg>
          </label>
          
          <a href="/" class={`mobile-link ${currentPath === '/' ? 'active' : ''}`}>Trang chủ</a>
          <a href="/posts" class={`mobile-link ${currentPath.startsWith('/posts') ? 'active' : ''}`}>Bài viết</a>
          <a href="/markdown-for-agents" class={`mobile-link ${currentPath === '/markdown-for-agents' ? 'active' : ''}`}>Markdown</a>
          
          <!-- Mobile theme switcher -->
          <div class="mobile-switcher-wrapper mt-4 pr-4">
            <button class="theme-toggle mobile-theme-toggle" aria-label="Chuyển sang tối">
              <div class="icon-container" style="width: 20px; height: 20px;">
                <svg class="icon sparkle" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>
                  <path d="M5 3v4"/>
                  <path d="M19 17v4"/>
                  <path d="M3 5h4"/>
                  <path d="M17 19h4"/>
                </svg>
              </div>
            </button>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
