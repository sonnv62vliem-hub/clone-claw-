---
import '../styles/global.css';
import Navbar from '../components/Navbar.svelte';
import Footer from '../components/Footer.svelte';
import MobileFAB from '../components/MobileFAB.svelte';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  currentPath?: string;
}

const {
  title = 'claw.ai.vn — OpenClaw AI Cho Người Mới và Ứng Dụng AI Thực Tế',
  description = 'OpenClaw AI cho người mới và mở rộng sang AI ứng dụng thực tế: tạo trợ lý cá nhân, tùy chỉnh agent, xây automation theo lộ trình rõ ràng.',
  ogImage = 'https://claw.ai.vn/og-image.jpg',
  canonical = 'https://claw.ai.vn/',
  currentPath = '/',
} = Astro.props;
---

<!doctype html>
<html lang="vi" data-theme="lobsterglass-light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="https://claw.ai.vn/_app/immutable/assets/claw-logo-red.DgE5HcFa.png" />
    
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
  </head>
  <body>
    <script>
      (function () {
        var saved = localStorage.getItem('theme');
        if (saved) document.documentElement.setAttribute('data-theme', saved);
      })();
    </script>
    
    <div class="foam-layer"></div>
    
    <div class="drawer drawer-end">
      <input id="app-drawer" type="checkbox" class="drawer-toggle" />
      
      <div class="app-shell drawer-content flex flex-col">
        <Navbar client:load currentPath={currentPath} />
        
        <main class="main-content">
          <div class="content-container">
            <slot />
          </div>
        </main>
        
        <Footer client:load />
        
        <MobileFAB client:load currentPath={currentPath} />
      </div>
    </div>
  </body>
</html>
